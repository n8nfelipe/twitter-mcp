# Environment variables for twitter-mcp
#
# You can either:
# 1) Set variables below directly (env fallback)
# 2) Store cookies in secret-vault-mcp and set VAULT_MASTER_PASSWORD
#    (see README for format of the vault entry)
#
# When TWITTER_USE_VAULT=auto (default), the vault is checked first.

TWITTER_AUTH_TOKEN=
TWITTER_CT0=
TWITTER_USER_ID=
TWITTER_CSRF_TOKEN=
TWITTER_USERNAME=

# Vault integration (optional)
# VAULT_MASTER_PASSWORD=
# TWITTER_USE_VAULT=auto
# TWITTER_VAULT_ENTRY=twitter-cookies
